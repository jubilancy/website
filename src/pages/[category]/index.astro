---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";

export async function getStaticPaths() {
  const categories = [
    "blog", "notes", "guides", "tools", "recipes", "research",
    "lists", "links", "favorite", "post", "archive", "computer",
    "series", "packages", "blogroll", "projects", "work", "gallery", "pages"
  ];

  const paths = await Promise.all(
    categories.map(async (category) => {
      const posts = await getCollection(category as any);
      return {
        params: { category },
        props: { posts },
      };
    })
  );

  return paths;
}

const { category } = Astro.params;
const { posts } = Astro.props as { posts: CollectionEntry<any>[] };

const sortedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const titleA = (a.data.title || a.slug).toLowerCase();
    const titleB = (b.data.title || b.slug).toLowerCase();
    return titleA.localeCompare(titleB);
  });
---

<PageLayout title={category} description={`Collection: ${category}`}>
  <section class="space-y-10">
    <div class="flex justify-between items-baseline">
      <h1 class="font-mono text-[11px] uppercase tracking-[0.2em] text-zinc-400">
        Index: {category}
      </h1>
      <a href="/" class="font-mono text-[11px] text-zinc-400 hover:text-black dark:hover:text-white transition-colors">
        back home
      </a>
    </div>

    <ul class="divide-y divide-zinc-100 dark:divide-zinc-800 border-t border-zinc-100 dark:border-zinc-800">
      {sortedPosts.map((post) => (
        <li class="group py-4">
          <a href={`/${category}/${post.slug}`} class="flex justify-between items-baseline no-underline">
            <span class="text-lg text-black dark:text-white group-hover:text-[var(--color-accent)] transition-colors">
              {post.data.title || post.slug.replace(/-/g, ' ')}
            </span>
            <span class="text-zinc-300 dark:text-zinc-700 text-xs font-mono lowercase">
              read ↗
            </span>
          </a>
        </li>
      ))}
    </ul>

    {sortedPosts.length === 0 && (
      <p class="text-zinc-400 italic font-mono text-sm">This folder is currently empty.</p>
    )}
  </section>
</PageLayout>
