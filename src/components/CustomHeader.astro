---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Header.astro';

// This helps us identify the current page
const { pathname } = Astro.url;
const isCurrent = (path: string) => 
  pathname === path || pathname === path.replace(/\/$/, '') ? 'active' : '';
---

<div class="header-wrapper">
  <Default {...Astro.props} />
  
  <nav class="horizontal-nav">
    <a href="/notes/" class={isCurrent('/notes/')}>Notes</a>
    <a href="/archive/" class={isCurrent('/archive/')}>Archive</a>
    <a href="/computer/" class={isCurrent('/computer/')}>Computer</a>
    <a href="/about/" class={isCurrent('/about/')}>About</a>
  </nav>
</div>

<style>
  .header-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .horizontal-nav {
    display: flex;
    gap: 2rem;
    padding: 0.5rem var(--sl-content-pad-x);
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-nav);
  }
  .horizontal-nav a {
    text-decoration: none;
    color: var(--sl-color-white);
    font-weight: 500;
  }
  .horizontal-nav a:hover {
    color: var(--sl-color-accent-high);
  }
  .horizontal-nav a.active {
    color: var(--sl-color-accent-high);
    border-bottom: 2px solid var(--sl-color-accent);
  }
</style>